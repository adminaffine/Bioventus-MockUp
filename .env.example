# Backend (FastAPI) - copy to backend/.env
# AI chat: use either Azure OpenAI (recommended) or standard OpenAI

# -----------------------------------------------------------------------------
# Azure OpenAI (optional)
# -----------------------------------------------------------------------------
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
# AZURE_OPENAI_DEPLOYMENT_GPT4O=your-gpt-4o-deployment-name

# -----------------------------------------------------------------------------
# Standard OpenAI (optional, if not using Azure)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-your-openai-api-key-here

# -----------------------------------------------------------------------------
# AI provider selection (ollama | azure | openai | auto)
# -----------------------------------------------------------------------------
# AI_PROVIDER=ollama

# -----------------------------------------------------------------------------
# Ollama (recommended for local Docker stack)
# -----------------------------------------------------------------------------
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=qwen2.5:3b-instruct
# OLLAMA_TIMEOUT_SEC=120

# Frontend (optional - defaults to same origin / proxy)
# VITE_API_URL=http://localhost8005
